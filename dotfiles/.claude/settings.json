{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(pnpm:*)",
      "Bash(uv:*)",
      "Bash(just:*)",
      "Bash(curl:*)",
      "Write",
      "Edit",
      "NotebookEdit"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "includeCoAuthoredBy": false,
  "tui": "fullscreen",
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
