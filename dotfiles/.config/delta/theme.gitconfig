[delta "popil"]
blame-palette = "#1c1917 #161210 #15110e #231e1a #2c2622"
commit-decoration-style = "#57534e" bold box ul
dark = true
file-decoration-style = "#57534e"
file-style = "#e7e5e4"
hunk-header-decoration-style = "#57534e" box ul
hunk-header-file-style = bold
hunk-header-line-number-style = bold "#a8a29e"
hunk-header-style = file line-number syntax
line-numbers-left-style = "#57534e"
line-numbers-minus-style = bold "#c98787"
line-numbers-plus-style = bold "#8ea98c"
line-numbers-right-style = "#57534e"
line-numbers-zero-style = "#57534e"
minus-emph-style = bold syntax "#59403e"
minus-style = syntax "#3f2f2d"
plus-emph-style = bold syntax "#444b40"
plus-style = syntax "#33362e"
map-styles = \
bold purple => syntax "#4d4154", \
bold blue => syntax "#3f4552", \
bold cyan => syntax "#3a454c", \
bold yellow => syntax "#584e3a"
syntax-theme = popil
