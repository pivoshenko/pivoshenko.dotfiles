{
  // == General ==
  "auto_update": true,
  "restore_on_startup": "launchpad",
  "session": {
    "trust_all_worktrees": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // == Theme ==
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "theme": {
    "mode": "system",
    "light": "popil",
    "dark": "popil",
  },
  // == Fonts ==
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 17,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 17,
  // == Editor ==
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "preview_tabs": {
    "enabled": false,
    "enable_keep_preview_on_code_navigation": false,
    "enable_preview_from_file_finder": false,
  },
  "relative_line_numbers": "enabled",
  "show_whitespaces": "all",
  "soft_wrap": "editor_width",
  // == Tabs ==
  "tabs": {
    "activate_on_close": "history",
    "close_position": "right",
    "file_icons": false,
    "git_status": true,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true,
  },
  // == Keybindings ==
  "base_keymap": "VSCode",
  "helix_mode": true,
  "vim_mode": false,
  "which_key": {
    "enabled": true,
  },
  // == Panels ==
  "agent": {
    "default_profile": "ask",
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "git_panel": {
    "button": true,
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
  },
  "terminal": {
    "button": false,
  },
  // == AI ==
  "disable_ai": true,
  "edit_predictions": {
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "mode": "eager",
    "provider": "zed",
  },
  // == Languages ==
  "languages": {
    "Python": {
      "language_servers": ["ty", "!pyright"],
    },
  },
  // == File Types ==
  "file_types": {
    "SQL": ["*.sql.j2"],
    "TOML": ["poetry.lock", "uv.lock"],
  },
  // == Extensions ==
  "auto_install_extensions": {
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "env": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "ini": true,
    "jinja2": true,
    "just": true,
    "material-icon-theme": true,
    "sql": true,
    "toml": true,
    "ty": true,
  },
}
